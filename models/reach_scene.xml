<mujoco model="reach_scene">
  <compiler angle="radian" autolimits="true"/>

  <option timestep="0.002" integrator="implicitfast"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8"
             width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true"
              texrepeat="5 5" reflectance="0.0"/>
  </asset>

  <worldbody>
    <camera name="overhead_cam" pos="0 0 0.65" xyaxes="1 0 0 0 1 0" fovy="65"/>
    <geom name="floor" type="plane" size="1 1 0.01" pos="0 0 -0.45"
          material="groundplane" contype="0" conaffinity="0"/>

    <light name="top_light" pos="0 0 1.0" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>

    <body name="table" pos="0 0 0">
      <geom name="table_top" type="box" size="0.35 0.35 0.02" pos="0 0 -0.02"
            rgba="0.55 0.45 0.35 1" contype="1" conaffinity="1"/>
      <geom name="table_leg_1" type="box" size="0.02 0.02 0.21" pos="0.3 0.3 -0.25"
            rgba="0.35 0.3 0.25 1" contype="1" conaffinity="1"/>
      <geom name="table_leg_2" type="box" size="0.02 0.02 0.21" pos="-0.3 0.3 -0.25"
            rgba="0.35 0.3 0.25 1" contype="1" conaffinity="1"/>
      <geom name="table_leg_3" type="box" size="0.02 0.02 0.21" pos="0.3 -0.3 -0.25"
            rgba="0.35 0.3 0.25 1" contype="1" conaffinity="1"/>
      <geom name="table_leg_4" type="box" size="0.02 0.02 0.21" pos="-0.3 -0.3 -0.25"
            rgba="0.35 0.3 0.25 1" contype="1" conaffinity="1"/>
    </body>

    <body name="target" pos="0.12 0.10 0.10" mocap="true">
      <geom name="target_geom" type="sphere" size="0.015"
            rgba="1.0 0.15 0.15 0.55" contype="0" conaffinity="0"/>
      <site name="target_site" pos="0 0 0" size="0.005" rgba="1 1 1 0"/>
    </body>
  </worldbody>
</mujoco>
